# Copy this file to `.env` and adjust as needed.

# MongoDB connection string. Local default shown below.
# In production (e.g. Railway), set MONGODB_URI instead — it takes priority
# over MONGO_URI, which is kept for local-dev backwards compatibility.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=eureka

# JWT signing secret — CHANGE THIS to a long random string in production.
JWT_SECRET=dev-secret-change-me-to-something-long-and-random
JWT_ALGORITHM=HS256
# Access token lifetime in minutes (default 30 days for easy mobile testing).
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Comma-separated browser origins allowed by CORS. Doesn't affect native/mobile
# clients — only browsers enforce CORS.
CORS_ORIGINS=http://localhost:3000,https://projecteureka.vercel.app

# Shared secret guarding the protected admin routes (e.g. POST /admin/agent/post,
# used by the external content agent). Set a long random string in production;
# leaving it blank disables those routes entirely.
EUREKA_ADMIN_TOKEN=change-me-to-a-long-random-admin-token
